<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- GÜNLÜK RAPOR -->
    <template id="report_gym_daily_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 class="text-center">Spor Salonu Giriş Raporu</h2>
                    <table class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Referans</th>
                                <th>Ad Soyad</th>
                                <th>Öğrenci No</th>
                                <th>Bölüm</th>
                                <th>Giriş Saati</th>
                                <th>Çıkış Saati</th>
                                <th>Toplam (dk)</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="doc">
                                <tr>
                                    <td><t t-esc="doc.name"/></td>
                                    <td><t t-esc="doc.full_name"/></td>
                                    <td><t t-esc="doc.student_number"/></td>
                                    <td><t t-esc="doc.department"/></td>
                                    <td><t t-esc="doc.check_in_time"/></td>
                                    <td><t t-esc="doc.check_out_time or '-'"/></td>
                                    <td><t t-esc="doc.total_minutes or '-'"/></td>
                                    <td><t t-esc="doc.state"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- QR KOD RAPORU -->
    <template id="report_gym_qr_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page text-center">
                    <h2>Spor Salonu Giriş QR Kodu</h2>
                    <p class="text-muted">Aşağıdaki QR kodu okutarak spor salonuna giriş yapabilirsiniz.</p>
                    <div class="mt-4">
                        <t t-foreach="docs" t-as="doc">
                       <t t-set="_raw" t-value="doc.qr_code_image or ''"/>
                       <t t-set="qr_b64" t-value="(_raw.decode('utf-8') if isinstance(_raw, bytes) else _raw)"/>
                       <img t-if="qr_b64"
                           t-att-src="'data:image/png;base64,%s' % qr_b64"
                           style="width:300px; height:300px;"/>
                            <p t-else="" class="text-warning">QR kod henüz oluşturulamadı. Kayıt yeniden açıldıktan sonra tekrar deneyin.</p>
                            <p class="mt-3">
                                <strong>URL: </strong>
                                <t t-esc="doc.qr_code_url or '-'"/>
                            </p>
                        </t>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>