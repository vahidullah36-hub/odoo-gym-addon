<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_gym" model="ir.ui.view">
        <field name="name">res.config.settings.view.gym</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block"
                     data-string="Spor Salonu"
                     data-key="gym_management"
                     groups="gym_management.group_gym_manager">
                    <h2>Spor Salonu Ayarları</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Varsayılan Kullanım Süresi (Dakika)</span>
                                <div class="text-muted">
                                    Öğrencilerin spor salonunda kalabileceği maksimum süre
                                </div>
                                <div class="content-group mt8">
                                    <field name="gym_allowed_minutes"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>