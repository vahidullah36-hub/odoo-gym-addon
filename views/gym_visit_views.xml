<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_gym_visit_list" model="ir.ui.view">
        <field name="name">gym.visit.list</field>
        <field name="model">gym.visit</field>
        <field name="arch" type="xml">
            <list string="Ziyaretler"
                  decoration-success="color_state == 'green'"
                  decoration-warning="color_state == 'yellow'"
                  decoration-danger="color_state == 'red'"
                  decoration-muted="state == 'checked_out'">
                <field name="name"/>
                <field name="full_name"/>
                <field name="student_number"/>
                <field name="department"/>
                <field name="check_in_time"/>
                <field name="elapsed_minutes" string="Gecen (dk)"/>
                <field name="remaining_minutes" string="Kalan (dk)"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'expired'"
                       decoration-danger="state == 'checked_out'"/>
                <field name="color_state" column_invisible="1"/>
                <button name="action_check_out"
                        string="Cikis Yap"
                        type="object"
                        icon="fa-sign-out"
                        invisible="state == 'checked_out'"
                        groups="gym_management.group_gym_manager"/>
            </list>
        </field>
    </record>

    <record id="view_gym_visit_form" model="ir.ui.view">
        <field name="name">gym.visit.form</field>
        <field name="model">gym.visit</field>
        <field name="arch" type="xml">
            <form string="Ziyaret Detayi">
                <header>
                    <button name="action_check_out"
                            string="Cikis Yap"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'checked_out'"
                            groups="gym_management.group_gym_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,expired,checked_out"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Ogrenci Bilgileri">
                            <field name="student_name"/>
                            <field name="student_surname"/>
                            <field name="student_number"/>
                            <field name="department"/>
                        </group>
                        <group string="Zaman Bilgileri">
                            <field name="check_in_time"/>
                            <field name="check_out_time"/>
                            <field name="allowed_minutes"/>
                            <field name="elapsed_minutes"/>
                            <field name="remaining_minutes"/>
                            <field name="total_minutes"
                                   invisible="state != 'checked_out'"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_gym_visit_kanban" model="ir.ui.view">
        <field name="name">gym.visit.kanban</field>
        <field name="model">gym.visit</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="color_state"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="
                            #{record.color_state.raw_value == 'green' ? 'border-success' : ''}
                            #{record.color_state.raw_value == 'yellow' ? 'border-warning' : ''}
                            #{record.color_state.raw_value == 'red' ? 'border-danger' : ''}
                            p-2">
                            <strong><field name="full_name"/></strong>
                            <div><field name="student_number"/></div>
                            <div><field name="department"/></div>
                            <div>Giris: <field name="check_in_time"/></div>
                            <div>Gecen: <field name="elapsed_minutes"/> dk</div>
                            <div>Kalan: <field name="remaining_minutes"/> dk</div>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'active'"
                                   decoration-warning="state == 'expired'"
                                   decoration-danger="state == 'checked_out'"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_gym_visit_search" model="ir.ui.view">
        <field name="name">gym.visit.search</field>
        <field name="model">gym.visit</field>
        <field name="arch" type="xml">
            <search string="Ziyaret Ara">
                <field name="full_name" string="Ad Soyad"/>
                <field name="student_number" string="Ogrenci No"/>
                <field name="department" string="Bolum"/>
                <separator/>
                <filter name="active_students"
                        string="Iceridekiler"
                        domain="[('state','in',['active','expired'])]"/>
                <filter name="expired_students"
                        string="Suresi Dolanlar"
                        domain="[('state','=','expired')]"/>
                <filter name="checked_out"
                        string="Cikis Yapanlar"
                        domain="[('state','=','checked_out')]"/>
                <separator/>
                <filter name="today"
                        string="Bugun"
                        domain="[('check_in_time','&gt;=', datetime.datetime.now().strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Grupla">
                    <filter name="group_department"
                            string="Bolume Gore"
                            context="{'group_by': 'department'}"/>
                    <filter name="group_state"
                            string="Duruma Gore"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gym_visit" model="ir.actions.act_window">
        <field name="name">Ziyaretler</field>
        <field name="res_model">gym.visit</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_active_students': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Henuz ziyaret kaydi yok!
            </p>
            <p>QR kodu okutarak ilk kaydi olusturun.</p>
        </field>
    </record>

    <record id="action_gym_visit_history" model="ir.actions.act_window">
        <field name="name">Gecmis Ziyaretler</field>
        <field name="res_model">gym.visit</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','checked_out')]</field>
    </record>

    <record id="view_gym_qr_form" model="ir.ui.view">
        <field name="name">gym.visit.qr.form</field>
        <field name="model">gym.visit</field>
        <field name="arch" type="xml">
            <form string="QR Kod">
                <sheet>
                    <div class="text-center">
                        <h2>Spor Salonu Giris QR Kodu</h2>
                        <p class="text-muted">Ogrenciler bu kodu okutarak giris yapabilir</p>
                        <div class="mt-4 mb-4">
                            <img src="/gym/qr"
                                 alt="Spor Salonu QR Kod"
                                 style="width:300px; height:300px; border:1px solid #ddd; padding:10px;"/>
                        </div>
                        <div class="mt-2 mb-4">
                            <p>
                                <strong>Kayit URL: </strong>
                                http://localhost:8069/gym/register
                            </p>
                        </div>
                        <div class="mt-4">
                            <button string="QR Kodu Yazdir"
                                    name="action_print_qr"
                                    type="object"
                                    class="btn btn-primary btn-lg"/>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gym_qr_code_server" model="ir.actions.server">
        <field name="name">QR Kod Göster</field>
        <field name="model_id" ref="model_gym_visit"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_open_qr()
        </field>
    </record>

</odoo>